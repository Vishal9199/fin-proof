# ──────────────────────────────────────────────────────────────────────────
# Ledger Sentinel — environment configuration
# Copy to `.env` and fill in. Only ANTHROPIC_API_KEY is required to run live.
# ──────────────────────────────────────────────────────────────────────────

# Required for live extraction/reconciliation. Without it the system runs in
# DETERMINISTIC MOCK mode (replays canned extractions) so the demo never fails.
ANTHROPIC_API_KEY=

# Model routing. Haiku handles clean docs cheaply; Opus is escalated to only
# for low-confidence / ambiguous extractions (see ARCHITECTURE.md "Cost").
LEDGER_MODEL_FAST=claude-haiku-4-5-20251001
LEDGER_MODEL_DEEP=claude-opus-4-8

# AgentOps / observability (optional). If unset, traces are kept in-process
# and still rendered on the AgentOps tab — Langfuse just adds persistence.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Confidence gate: extractions below this route to the QUARANTINE lane.
LEDGER_CONFIDENCE_THRESHOLD=0.80

# Reconciliation fuzzy-match acceptance threshold (0-1).
LEDGER_MATCH_THRESHOLD=0.82

# Max extraction workers to fan out concurrently.
LEDGER_MAX_CONCURRENCY=8
